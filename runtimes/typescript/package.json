{
  "name": "@genreport/runtime",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript runtime foundation for loading, parsing, and validating GenReport Definition files.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
