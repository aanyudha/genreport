{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genreport.dev/schema/genreport.schema.json",
  "title": "GenReport Definition",
  "description": "Draft GenReport Definition v0.1 schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "report", "datasource", "columns"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Definition version.",
      "enum": ["0.1"]
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "datasource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "table"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["table"]
        },
        "table": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "filters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/filter"
      }
    },
    "columns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/column"
      }
    },
    "sorting": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sorting"
      }
    },
    "grouping": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "summary": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/summary"
      }
    },
    "exports": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["html", "csv", "excel", "pdf"]
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "filter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "date", "datetime"]
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "column": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "label", "type"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "integer", "boolean", "date", "datetime"]
        }
      }
    },
    "sorting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "direction"],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "function"],
      "properties": {
        "field": {
          "type": "string",
          "minLength": 1
        },
        "function": {
          "type": "string",
          "enum": ["sum", "avg", "min", "max", "count"]
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
